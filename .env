# ============================================
# OAuth Configuration
# ============================================
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=1074960501914-c965vd5ut1fihhs3gkpat7g87edf5km6.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=n/a
# Firebase web OAuth client (required by GoogleSignin.configure webClientId)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=582446711871-na6ll4kvi7t1mm6pgcn8qt2at50qf37k.apps.googleusercontent.com

# ============================================
# RevenueCat (in-app purchases)
# ============================================
# Public SDK keys (safe to ship in the client). appl_* targets the App Store
# (products must exist in App Store Connect and be attached in RevenueCat);
# test_* targets the RevenueCat Test Store (simulated purchases, no store
# setup needed). Android still uses the Test Store until a goog_* key exists.
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_DyoiwiVgGfEBXSfwbMHpRfTsgEX
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=test_pScUbcsvKDZWCqlKQLYMxrFEZUA

# ============================================
# Logging Configuration
# ============================================
# Log level: silent | error | warn | info | debug | verbose
# - silent:  No logging output
# - error:   Only errors
# - warn:    Warnings and errors
# - info:    Info, warnings, and errors (default)
# - debug:   Debug, info, warnings, and errors
# - verbose: Maximum detail including traces
EXPO_PUBLIC_LOG_LEVEL=info

# Log categories (comma-separated, or * for all)
# Available categories: api, sync, auth, storage, navigation, ui, redux, saga, network, image, ai, purchases, general
# Example: EXPO_PUBLIC_LOG_CATEGORIES=api,sync,auth
EXPO_PUBLIC_LOG_CATEGORIES=*

# Show timestamps in logs
EXPO_PUBLIC_LOG_TIMESTAMPS=true

# Show emojis in logs (for easy visual identification)
EXPO_PUBLIC_LOG_EMOJIS=true
